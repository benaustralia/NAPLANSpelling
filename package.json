  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "prebuild": "bun run scripts/build-data.ts",
    "dev": "bun run scripts/build-data.ts && vite",
    "build": "tsc -b && vite build && bun run scripts/inline-css.ts",
